<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cf_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/cf_screen_padding">

        <Button
            android:id="@+id/topic_detail_back_button"
            style="@style/Widget.CampusForum.Button.Secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cf_action_back" />

        <LinearLayout
            style="@style/Widget.CampusForum.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_section_spacing"
            android:orientation="vertical">

            <TextView
                android:id="@+id/topic_detail_category"
                style="@style/Widget.CampusForum.Chip.Default"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/cf_chip_height"
                android:gravity="center" />

            <TextView
                android:id="@+id/topic_detail_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:textAppearance="@style/TextAppearance.CampusForum.Headline" />

            <TextView
                android:id="@+id/topic_detail_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:textAppearance="@style/TextAppearance.CampusForum.Caption" />

            <TextView
                android:id="@+id/topic_detail_created_at"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_1"
                android:textAppearance="@style/TextAppearance.CampusForum.Caption" />

            <TextView
                android:id="@+id/topic_detail_reply_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_1"
                android:textAppearance="@style/TextAppearance.CampusForum.Caption" />

            <Button
                android:id="@+id/topic_detail_actions_button"
                style="@style/Widget.CampusForum.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:contentDescription="@string/cf_action_more_description"
                android:text="@string/cf_action_more"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            style="@style/Widget.CampusForum.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_spacing_4"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cf_topic_detail_content_label"
                android:textAppearance="@style/TextAppearance.CampusForum.Title" />

            <TextView
                android:id="@+id/topic_detail_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:textAppearance="@style/TextAppearance.CampusForum.Body" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_section_spacing"
            android:text="@string/cf_topic_detail_replies_section_title"
            android:textAppearance="@style/TextAppearance.CampusForum.Title" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/topic_detail_replies_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_spacing_3"
            android:nestedScrollingEnabled="false" />

        <LinearLayout
            android:id="@+id/topic_detail_replies_empty_state"
            style="@style/Widget.CampusForum.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_spacing_3"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cf_topic_detail_replies_empty_title"
                android:textAppearance="@style/TextAppearance.CampusForum.BodySmall" />
        </LinearLayout>

        <LinearLayout
            style="@style/Widget.CampusForum.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_spacing_4"
            android:layout_marginBottom="@dimen/cf_spacing_6"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cf_topic_detail_reply_form_title"
                android:textAppearance="@style/TextAppearance.CampusForum.Title" />

            <EditText
                android:id="@+id/topic_detail_reply_input"
                style="@style/Widget.CampusForum.Input"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:gravity="top|start"
                android:hint="@string/cf_topic_detail_reply_hint"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="4" />

            <Button
                android:id="@+id/topic_detail_send_reply_button"
                style="@style/Widget.CampusForum.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:text="@string/cf_topic_detail_reply_send" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
