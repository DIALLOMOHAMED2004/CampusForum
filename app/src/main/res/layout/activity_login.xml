<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cf_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- En-tête dégradé -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="@dimen/cf_spacing_8"
            android:paddingBottom="@dimen/cf_spacing_8">

            <TextView
                style="@style/Widget.CampusForum.BrandMark.OnDark"
                android:layout_width="@dimen/cf_brand_mark_size"
                android:layout_height="@dimen/cf_brand_mark_size"
                android:gravity="center"
                android:text="@string/cf_brand_initials"
                android:textColor="@color/cf_on_primary"
                android:textSize="@dimen/cf_text_headline"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_4"
                android:text="@string/cf_login_title"
                android:textAppearance="@style/TextAppearance.CampusForum.Display"
                android:textSize="@dimen/cf_text_headline" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_1"
                android:text="@string/cf_login_subtitle"
                android:textAppearance="@style/TextAppearance.CampusForum.Subtitle.OnPrimary" />
        </LinearLayout>

        <!-- Formulaire -->
        <LinearLayout
            android:id="@+id/login_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/cf_screen_padding">

            <EditText
                android:id="@+id/login_email_input"
                style="@style/Widget.CampusForum.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_4"
                android:autofillHints="emailAddress"
                android:hint="@string/cf_label_email"
                android:inputType="textEmailAddress" />

            <EditText
                android:id="@+id/login_password_input"
                style="@style/Widget.CampusForum.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:autofillHints="password"
                android:hint="@string/cf_label_password"
                android:inputType="textPassword" />

            <TextView
                android:id="@+id/login_forgot_password_link"
                style="@style/Widget.CampusForum.TextLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:padding="@dimen/cf_spacing_2"
                android:text="@string/cf_login_forgot_password" />

            <Button
                android:id="@+id/login_button"
                style="@style/Widget.CampusForum.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:text="@string/cf_login_action" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_section_spacing"
                android:gravity="center"
                android:text="@string/cf_login_new_user"
                android:textAppearance="@style/TextAppearance.CampusForum.Caption" />

            <Button
                android:id="@+id/login_create_account_button"
                style="@style/Widget.CampusForum.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:layout_marginBottom="@dimen/cf_spacing_6"
                android:text="@string/cf_login_create_account" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
