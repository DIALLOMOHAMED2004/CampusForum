<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cf_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/cf_background"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/cf_screen_padding">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cf_home_title"
                android:textAppearance="@style/TextAppearance.CampusForum.Headline" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_2"
                android:text="@string/cf_home_subtitle"
                android:textAppearance="@style/TextAppearance.CampusForum.Body" />

            <EditText
                android:id="@+id/home_search_input"
                style="@style/Widget.CampusForum.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_section_spacing"
                android:autofillHints=""
                android:hint="@string/cf_home_search_hint"
                android:inputType="text" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_4"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/home_category_chips_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/home_filter_all_chip"
                        style="@style/Widget.CampusForum.Chip.Selected"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/cf_chip_height"
                        android:gravity="center"
                        android:text="@string/cf_home_filter_all" />
                </LinearLayout>
            </HorizontalScrollView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/home_topics_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_section_spacing"
                android:nestedScrollingEnabled="false" />

            <LinearLayout
                android:id="@+id/home_empty_state"
                style="@style/Widget.CampusForum.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_section_spacing"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cf_home_empty_title"
                    android:textAppearance="@style/TextAppearance.CampusForum.Title" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/cf_spacing_2"
                    android:text="@string/cf_home_empty_message"
                    android:textAppearance="@style/TextAppearance.CampusForum.BodySmall" />
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="88dp" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/home_create_topic_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/cf_spacing_4"
        android:contentDescription="@string/cf_home_create_topic"
        app:backgroundTint="@color/cf_primary"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="@color/cf_on_primary" />
</FrameLayout>
