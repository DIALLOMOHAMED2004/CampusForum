<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cf_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/cf_screen_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cf_admin_title"
                    android:textAppearance="@style/TextAppearance.CampusForum.Headline" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/cf_spacing_1"
                    android:text="@string/cf_admin_subtitle"
                    android:textAppearance="@style/TextAppearance.CampusForum.BodySmall" />
            </LinearLayout>

            <TextView
                style="@style/Widget.CampusForum.Chip.Selected"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/cf_chip_height"
                android:layout_marginStart="@dimen/cf_spacing_3"
                android:gravity="center"
                android:text="@string/cf_admin_badge" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_section_spacing"
            android:text="@string/cf_admin_overview_section"
            android:textAppearance="@style/TextAppearance.CampusForum.Title" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_spacing_3"
            android:orientation="horizontal">

            <LinearLayout
                style="@style/Widget.CampusForum.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/cf_chip_height"
                        android:layout_height="@dimen/cf_chip_height"
                        android:background="@drawable/bg_chip_default"
                        android:contentDescription="@string/cf_dashboard_stat_topics_icon"
                        android:padding="@dimen/cf_spacing_2"
                        android:src="@drawable/ic_dashboard_topics"
                        android:tint="@color/cf_primary" />

                    <TextView
                        android:id="@+id/admin_topics_count"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/cf_spacing_3"
                        android:layout_weight="1"
                        android:text="@string/cf_dashboard_stat_topics_count"
                        android:textAppearance="@style/TextAppearance.CampusForum.Headline" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/cf_spacing_2"
                    android:text="@string/cf_dashboard_active_topics"
                    android:textAppearance="@style/TextAppearance.CampusForum.Caption" />
            </LinearLayout>

            <LinearLayout
                style="@style/Widget.CampusForum.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cf_spacing_3"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/cf_chip_height"
                        android:layout_height="@dimen/cf_chip_height"
                        android:background="@drawable/bg_chip_default"
                        android:contentDescription="@string/cf_dashboard_stat_replies_icon"
                        android:padding="@dimen/cf_spacing_2"
                        android:src="@drawable/ic_dashboard_replies"
                        android:tint="@color/cf_primary" />

                    <TextView
                        android:id="@+id/admin_replies_count"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/cf_spacing_3"
                        android:layout_weight="1"
                        android:text="@string/cf_dashboard_stat_replies_count"
                        android:textAppearance="@style/TextAppearance.CampusForum.Headline" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/cf_spacing_2"
                    android:text="@string/cf_dashboard_replies"
                    android:textAppearance="@style/TextAppearance.CampusForum.Caption" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_spacing_3"
            android:orientation="horizontal">

            <LinearLayout
                style="@style/Widget.CampusForum.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/cf_chip_height"
                        android:layout_height="@dimen/cf_chip_height"
                        android:background="@drawable/bg_chip_default"
                        android:contentDescription="@string/cf_dashboard_stat_categories_icon"
                        android:padding="@dimen/cf_spacing_2"
                        android:src="@drawable/ic_dashboard_categories"
                        android:tint="@color/cf_primary" />

                    <TextView
                        android:id="@+id/admin_categories_count"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/cf_spacing_3"
                        android:layout_weight="1"
                        android:text="@string/cf_dashboard_stat_categories_count"
                        android:textAppearance="@style/TextAppearance.CampusForum.Headline" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/cf_spacing_2"
                    android:text="@string/cf_dashboard_categories"
                    android:textAppearance="@style/TextAppearance.CampusForum.Caption" />
            </LinearLayout>

            <LinearLayout
                style="@style/Widget.CampusForum.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/cf_spacing_3"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/cf_chip_height"
                        android:layout_height="@dimen/cf_chip_height"
                        android:background="@drawable/bg_chip_default"
                        android:contentDescription="@string/cf_dashboard_stat_members_icon"
                        android:padding="@dimen/cf_spacing_2"
                        android:src="@drawable/ic_dashboard_members"
                        android:tint="@color/cf_primary" />

                    <TextView
                        android:id="@+id/admin_members_count"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/cf_spacing_3"
                        android:layout_weight="1"
                        android:text="@string/cf_dashboard_stat_members_count"
                        android:textAppearance="@style/TextAppearance.CampusForum.Headline" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/cf_spacing_2"
                    android:text="@string/cf_dashboard_members"
                    android:textAppearance="@style/TextAppearance.CampusForum.Caption" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            style="@style/Widget.CampusForum.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_section_spacing"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cf_admin_categories_section"
                android:textAppearance="@style/TextAppearance.CampusForum.Title" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_1"
                android:text="@string/cf_admin_categories_help"
                android:textAppearance="@style/TextAppearance.CampusForum.BodySmall" />

            <EditText
                android:id="@+id/admin_category_name_input"
                style="@style/Widget.CampusForum.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:hint="@string/cf_admin_category_name_hint"
                android:inputType="textCapSentences" />

            <EditText
                android:id="@+id/admin_category_description_input"
                style="@style/Widget.CampusForum.Input"
                android:layout_width="match_parent"
                android:layout_height="@dimen/cf_admin_description_height"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:gravity="top|start"
                android:hint="@string/cf_admin_category_description_hint"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3" />

            <Button
                android:id="@+id/admin_category_add_button"
                style="@style/Widget.CampusForum.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:text="@string/cf_admin_category_add" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_section_spacing"
            android:text="@string/cf_admin_active_categories"
            android:textAppearance="@style/TextAppearance.CampusForum.Title" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/admin_categories_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_spacing_3"
            android:nestedScrollingEnabled="false" />

        <LinearLayout
            android:id="@+id/admin_categories_empty_state"
            style="@style/Widget.CampusForum.EmptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_spacing_3"
            android:layout_marginBottom="@dimen/cf_spacing_6"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="@dimen/cf_empty_icon_size"
                android:layout_height="@dimen/cf_empty_icon_size"
                android:contentDescription="@string/cf_admin_categories_empty_title"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_empty_state"
                android:tint="@color/cf_primary_light" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:gravity="center"
                android:text="@string/cf_admin_categories_empty_title"
                android:textAppearance="@style/TextAppearance.CampusForum.Title" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_1"
                android:gravity="center"
                android:text="@string/cf_admin_categories_empty_message"
                android:textAppearance="@style/TextAppearance.CampusForum.BodySmall" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
