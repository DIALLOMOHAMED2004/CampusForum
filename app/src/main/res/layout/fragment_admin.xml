<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cf_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/cf_screen_padding">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cf_admin_title"
            android:textAppearance="@style/TextAppearance.CampusForum.Headline" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_spacing_2"
            android:text="@string/cf_admin_subtitle"
            android:textAppearance="@style/TextAppearance.CampusForum.Body" />

        <LinearLayout
            style="@style/Widget.CampusForum.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_section_spacing"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cf_admin_categories_section"
                android:textAppearance="@style/TextAppearance.CampusForum.Title" />

            <EditText
                android:id="@+id/admin_category_name_input"
                style="@style/Widget.CampusForum.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:hint="@string/cf_admin_category_name_hint"
                android:inputType="textCapSentences" />

            <EditText
                android:id="@+id/admin_category_description_input"
                style="@style/Widget.CampusForum.Input"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:gravity="top|start"
                android:hint="@string/cf_admin_category_description_hint"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3" />

            <Button
                android:id="@+id/admin_category_add_button"
                style="@style/Widget.CampusForum.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_3"
                android:text="@string/cf_admin_category_add" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_section_spacing"
            android:text="@string/cf_admin_active_categories"
            android:textAppearance="@style/TextAppearance.CampusForum.Title" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/admin_categories_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_spacing_3"
            android:nestedScrollingEnabled="false" />

        <LinearLayout
            android:id="@+id/admin_categories_empty_state"
            style="@style/Widget.CampusForum.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_spacing_3"
            android:layout_marginBottom="@dimen/cf_spacing_6"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cf_admin_categories_empty_title"
                android:textAppearance="@style/TextAppearance.CampusForum.Title" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/cf_spacing_1"
                android:text="@string/cf_admin_categories_empty_message"
                android:textAppearance="@style/TextAppearance.CampusForum.BodySmall" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
