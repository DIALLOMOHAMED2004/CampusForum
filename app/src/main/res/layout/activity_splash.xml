<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_brand_gradient">

    <LinearLayout
        android:id="@+id/splash_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="@dimen/cf_spacing_8"
        android:paddingEnd="@dimen/cf_spacing_8"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            style="@style/Widget.CampusForum.BrandMark.OnDark"
            android:layout_width="@dimen/cf_brand_mark_size_large"
            android:layout_height="@dimen/cf_brand_mark_size_large"
            android:gravity="center"
            android:text="@string/cf_brand_initials"
            android:textColor="@color/cf_on_primary"
            android:textSize="@dimen/cf_text_display"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_spacing_6"
            android:gravity="center"
            android:text="@string/app_name"
            android:textAppearance="@style/TextAppearance.CampusForum.Display" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_spacing_2"
            android:gravity="center"
            android:text="@string/cf_splash_tagline"
            android:textAppearance="@style/TextAppearance.CampusForum.Subtitle.OnPrimary" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/cf_spacing_8"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:indeterminateTint="@color/cf_accent_light" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/cf_spacing_4"
            android:gravity="center"
            android:text="@string/cf_splash_offline_note"
            android:textAppearance="@style/TextAppearance.CampusForum.Subtitle.OnPrimary" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
