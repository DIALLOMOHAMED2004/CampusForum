<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.CampusForum.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/cf_on_primary</item>
        <item name="android:minHeight">@dimen/cf_button_height</item>
        <item name="android:paddingStart">@dimen/cf_spacing_4</item>
        <item name="android:paddingEnd">@dimen/cf_spacing_4</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/cf_text_body</item>
    </style>

    <style name="Widget.CampusForum.Input" parent="@android:style/Widget.EditText">
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:textColor">@color/cf_text_primary</item>
        <item name="android:textColorHint">@color/cf_text_hint</item>
        <item name="android:minHeight">@dimen/cf_input_height</item>
        <item name="android:paddingStart">@dimen/cf_spacing_4</item>
        <item name="android:paddingEnd">@dimen/cf_spacing_4</item>
        <item name="android:textSize">@dimen/cf_text_body</item>
    </style>

    <style name="Widget.CampusForum.Card" parent="@android:style/Widget">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">@dimen/cf_card_padding</item>
    </style>

    <style name="Widget.CampusForum.Chip.Default" parent="Widget.MaterialComponents.Chip.Action">
        <item name="android:background">@drawable/bg_chip_default</item>
        <item name="chipBackgroundColor">@color/cf_surface_secondary</item>
        <item name="android:textColor">@color/cf_text_secondary</item>
        <item name="android:minHeight">@dimen/cf_chip_height</item>
        <item name="android:paddingStart">@dimen/cf_spacing_4</item>
        <item name="android:paddingEnd">@dimen/cf_spacing_4</item>
        <item name="android:textSize">@dimen/cf_text_body_small</item>
    </style>

    <style name="Widget.CampusForum.Chip.Selected" parent="Widget.MaterialComponents.Chip.Action">
        <item name="android:background">@drawable/bg_chip_selected</item>
        <item name="chipBackgroundColor">@color/cf_primary</item>
        <item name="android:textColor">@color/cf_on_primary</item>
        <item name="android:minHeight">@dimen/cf_chip_height</item>
        <item name="android:paddingStart">@dimen/cf_spacing_4</item>
        <item name="android:paddingEnd">@dimen/cf_spacing_4</item>
        <item name="android:textSize">@dimen/cf_text_body_small</item>
    </style>

    <style name="TextAppearance.CampusForum.Headline" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/cf_text_primary</item>
        <item name="android:textSize">@dimen/cf_text_headline</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.CampusForum.Title" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/cf_text_primary</item>
        <item name="android:textSize">@dimen/cf_text_title</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.CampusForum.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/cf_text_secondary</item>
        <item name="android:textSize">@dimen/cf_text_body</item>
    </style>

    <style name="TextAppearance.CampusForum.BodySmall" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/cf_text_secondary</item>
        <item name="android:textSize">@dimen/cf_text_body_small</item>
    </style>

    <style name="TextAppearance.CampusForum.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/cf_text_tertiary</item>
        <item name="android:textSize">@dimen/cf_text_caption</item>
    </style>
</resources>
