<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

    <!-- ============================================================= -->
    <!--  CampusForum — Palette « Académique chaleureux »              -->
    <!--  Vert forêt profond et soigné, accents miel/laiton,          -->
    <!--  surfaces ivoire. Le vert d'origine est conservé mais        -->
    <!--  approfondi et enrichi pour un rendu premium.                -->
    <!-- ============================================================= -->

    <!-- Vert de marque : forêt profond, plus saturé et élégant que l'ancien #5B8C5A -->
    <color name="cf_primary">#1F6F54</color>
    <color name="cf_primary_dark">#155240</color>
    <color name="cf_primary_light">#3E9E7A</color>
    <color name="cf_primary_pale">#E3F0EA</color>

    <!-- Dégradé de marque (header, splash, brand mark) -->
    <color name="cf_gradient_start">#23805F</color>
    <color name="cf_gradient_end">#12503D</color>

    <!-- Accent chaleureux : laiton/miel — la touche « surprise » qui réchauffe le vert -->
    <color name="cf_accent">#C8923B</color>
    <color name="cf_accent_light">#E4B763</color>
    <color name="cf_accent_pale">#F7EEDD</color>

    <!-- Surfaces ivoire : papier académique, pas de blanc clinique -->
    <color name="cf_background">#FBFAF7</color>
    <color name="cf_card">#FFFFFF</color>
    <color name="cf_surface_secondary">#F1F4F0</color>
    <color name="cf_input">#F3F5F1</color>
    <color name="cf_input_focused">#FFFFFF</color>

    <!-- Hiérarchie de texte (chaude, lisible) -->
    <color name="cf_text_primary">#16241D</color>
    <color name="cf_text_secondary">#46544D</color>
    <color name="cf_text_tertiary">#728078</color>
    <color name="cf_text_hint">#A2ADA6</color>

