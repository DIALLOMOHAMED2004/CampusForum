<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="@color/cf_disabled" />
            <corners android:radius="@dimen/cf_radius_medium" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/cf_primary" />
            <corners android:radius="@dimen/cf_radius_medium" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/cf_primary_dark" />
            <corners android:radius="@dimen/cf_radius_medium" />
        </shape>
    </item>
</selector>
