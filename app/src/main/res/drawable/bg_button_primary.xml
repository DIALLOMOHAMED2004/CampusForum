<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/cf_disabled" />
            <corners android:radius="@dimen/cf_radius_medium" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/cf_primary_dark" />
            <corners android:radius="@dimen/cf_radius_medium" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="@color/cf_gradient_start"
                android:endColor="@color/cf_gradient_end"
                android:type="linear" />
            <corners android:radius="@dimen/cf_radius_medium" />
        </shape>
    </item>
</selector>
