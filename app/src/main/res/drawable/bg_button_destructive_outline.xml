<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/cf_background" />
            <stroke android:width="@dimen/cf_stroke_width_thick" android:color="@color/cf_disabled" />
            <corners android:radius="@dimen/cf_radius_medium" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/cf_danger_surface" />
            <stroke android:width="@dimen/cf_stroke_width_thick" android:color="@color/cf_danger" />
            <corners android:radius="@dimen/cf_radius_medium" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/cf_card" />
            <stroke android:width="@dimen/cf_stroke_width_thick" android:color="@color/cf_danger" />
            <corners android:radius="@dimen/cf_radius_medium" />
        </shape>
    </item>
</selector>
